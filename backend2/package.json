{
  "name": "sojo-boutique-api",
  "version": "1.0.0",
  "description": "Backend API de Sojo Boutique — Hono + Cloudflare Workers + D1 + R2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:seed": "wrangler d1 execute soho-boutique-db --file=src/db/seed.sql",
    "db:seed:local": "wrangler d1 execute soho-boutique-db --local --file=src/db/seed.sql",
    "db:migrate": "wrangler d1 execute soho-boutique-db --file=src/db/migrations.sql",
    "db:migrate:local": "wrangler d1 execute soho-boutique-db --local --file=src/db/migrations.sql"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "drizzle-orm": "^0.39.0",
    "zod": "^3.24.0",
    "@hono/zod-validator": "^0.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@cloudflare/workers-types": "^4.20250410.0",
    "wrangler": "^4.10.0",
    "drizzle-kit": "^0.30.0"
  }
}
